// Copy this file to Secrets.local.xcconfig (same folder) and add your keys.
// Secrets.local.xcconfig is gitignored.
//
// IMPORTANT: In .xcconfig, "//" starts a comment — even inside "quotes".
// Use an empty build-setting substitution between slashes (not a bare //):
//   SUPABASE_URL = https:/$()/your-project.supabase.co
// expands to https://your-project.supabase.co

GEMINI_API_KEY = your_gemini_key_here
OPENROUTER_API_KEY = your_openrouter_key_here
SUPABASE_ANON_KEY = your_supabase_anon_key_here
SUPABASE_URL = https:/$()/your-project.supabase.co

// Optional: host web/recovery-bridge.html (e.g. GitHub Pages) and set this URL in Supabase Auth redirect allow list.
// Fixes Gmail / in-app browsers that block custom URL schemes. Otherwise omit to use the app scheme directly.
// PASSWORD_RESET_REDIRECT = https:/$()/youruser.github.io/leafid/recovery-bridge.html
