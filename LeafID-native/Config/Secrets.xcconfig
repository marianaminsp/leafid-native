// API keys for Info.plist substitution (GEMINI_API_KEY, OPENROUTER_API_KEY, SUPABASE_*).
// Empty defaults keep Release builds free of embedded secrets.
//
// Copy Secrets.local.xcconfig.example → Secrets.local.xcconfig and fill keys;
// that file is gitignored and overrides the lines below.
//
// SUPABASE_URL: cannot be raw https://... — // starts a comment (even in "quotes").
// Use: SUPABASE_URL = https:/$()/project-ref.supabase.co → https://project-ref...

GEMINI_API_KEY =
OPENROUTER_API_KEY =
SUPABASE_ANON_KEY =
SUPABASE_URL =
// Same rule as SUPABASE_URL: bare // starts an xcconfig comment — use /$()/ for ://
PASSWORD_RESET_REDIRECT = com.marianaminafro.leafid:/$()/reset-password

#include? "Secrets.local.xcconfig"
